{%- doc -%}
  Shared quick-view modal + toast notification, reused by both the shop
  grid pages and the product page. Render this exactly once per page —
  it uses fixed ids so a second instance would be inert dead markup.

  @param {object} section - The calling section (for aria id uniqueness)
{%- enddoc -%}

<div class="chosenhope-home-scope">
  <div id="chosenhope-quick-view-backdrop" class="modal-backdrop" role="presentation" data-qv-close>
    <div id="chosenhope-quick-view-modal" class="quick-view-modal" role="dialog" aria-modal="true" aria-labelledby="chosenhope-qv-title-{{ section.id }}">
      <button type="button" class="qv-close" data-qv-close aria-label="Close quick view">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M6 6l12 12M18 6 6 18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
      </button>
      <div class="quick-view-grid">
        <img data-qv="image" width="700" height="700" alt="" loading="lazy">
        <div>
          <h2 id="chosenhope-qv-title-{{ section.id }}" data-qv="title" style="font-size: 1.5rem;"></h2>
          <div class="product-rating" data-qv="rating" style="margin-top: 8px;"></div>
          <div class="product-price" data-qv="price" style="font-size: 1.125rem; margin-top: 8px;"></div>
          <p data-qv="desc" style="margin-top: 1rem; font-size: 0.9375rem; color: var(--ch-gray);"></p>
          <div style="display: flex; gap: 10px; margin-top: 1.5rem;">
            <button type="button" class="btn btn-gold" data-qv-add data-qv="add-btn">Add to cart</button>
            <a href="#" class="btn btn-outline" data-qv="view-link">View full details</a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div id="chosenhope-toast" class="toast" role="status" aria-live="polite"></div>
</div>
