{%- doc -%}
  Shared markup for a ChosenHope shop-page product grid (toolbar, filters,
  product grid, pagination, quick-view modal, toast). Rendered by each
  page-specific grid section (chosenhope-jewelry-grid, chosenhope-canvas-grid,
  chosenhope-apparel-grid, chosenhope-best-sellers-grid,
  chosenhope-collections-grid) so the visual design and behavior stay
  identical while each page keeps its own dedicated, individually-named
  section file.

  @param {object} section - The calling section (for id/settings)
  @param {object} collection - The Shopify collection whose products should render
{%- enddoc -%}

{% liquid
  assign show_filters = section.settings.show_filters
  assign products_per_page = section.settings.products_per_page
  assign active_filter_count = 0
  if show_filters and collection != blank
    for filter in collection.filters
      for value in filter.values
        if value.active
          assign active_filter_count = active_filter_count | plus: 1
        endif
      endfor
    endfor
  endif
%}

<div class="chosenhope-home-scope chosenhope-shop-grid">
  <div class="container">
    {% if collection == blank %}
      <div class="main-collection-grid__empty">
        <h2>{{ section.settings.empty_state_text }}</h2>
        <p>Pick a collection in the theme editor to show its products here.</p>
      </div>
    {% else %}
      {% paginate collection.products by products_per_page %}
      <form method="get" action="{{ collection.url }}" id="chosenhope-shop-form-{{ section.id }}">
        <div class="coll-toolbar">
          <p class="result-count">{{ paginate.items }} {{ section.settings.result_noun }}</p>
          <div class="toolbar-controls">
            {% if show_filters %}
              <button type="button" class="filter-toggle" data-filter-toggle aria-haspopup="dialog">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 6h16M7 12h10M10 18h4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                Filter
              </button>
            {% endif %}
            <div class="select-wrap">
              <label for="chosenhope-sort-{{ section.id }}">Sort by</label>
              <select id="chosenhope-sort-{{ section.id }}" name="sort_by" data-shop-sort>
                {% for option in collection.sort_options %}
                  <option value="{{ option.value }}" {% if option.value == collection.sort_by %}selected{% endif %}>{{ option.name }}</option>
                {% endfor %}
              </select>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            </div>
          </div>
        </div>

        {% if show_filters and active_filter_count > 0 %}
          <div class="active-filters">
            {% for filter in collection.filters %}
              {% for value in filter.values %}
                {% if value.active %}
                  <a href="{{ value.url_to_remove }}" class="chip">{{ filter.label }}: {{ value.label }} <span class="chip-remove" aria-hidden="true">&times;</span></a>
                {% endif %}
              {% endfor %}
            {% endfor %}
            <a href="{{ collection.url }}" class="chip clear-all">Clear all</a>
          </div>
        {% endif %}

        <div class="coll-layout{% unless show_filters %} coll-layout--no-filters{% endunless %}" style="{% unless show_filters %}grid-template-columns: 1fr;{% endunless %}">
          {% if show_filters %}
            {% assign desktop_id_prefix = 'f-desktop' | append: section.id %}
            <aside class="filters-panel" aria-label="Filter products">
              {% render 'chosenhope-shop-filters', collection: collection, id_prefix: desktop_id_prefix %}
              <button type="submit" class="btn btn-gold filters-apply">Apply filters</button>
              <a href="{{ collection.url }}" class="filters-clear">Clear all filters</a>
            </aside>
          {% endif %}

          <div>
            {% if collection.products.size == 0 %}
              <div class="main-collection-grid__empty">
                <h2>{{ section.settings.empty_state_text }}</h2>
              </div>
            {% else %}
              <div class="product-grid">
                {% for product in collection.products %}
                  {% render 'chosenhope-product-card',
                    product: product,
                    best_seller_tag: section.settings.best_seller_tag,
                    new_tag: section.settings.new_tag,
                    forloop_index0: forloop.index0
                  %}
                {% endfor %}
              </div>
            {% endif %}

            {% if paginate.pages > 1 %}
              <nav class="pagination" aria-label="Pagination">
                {% if paginate.previous %}
                  <a href="{{ paginate.previous.url }}" class="nav-arrow nav-arrow--prev" aria-label="Previous page"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M15 6l-6 6 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg> Previous</a>
                {% else %}
                  <span class="nav-arrow nav-arrow--prev" aria-disabled="true"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M15 6l-6 6 6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg> Previous</span>
                {% endif %}

                {% for part in paginate.parts %}
                  {% if part.is_link %}
                    <a href="{{ part.url }}">{{ part.title }}</a>
                  {% elsif part.title == paginate.current_page %}
                    <span class="current" aria-current="page">{{ part.title }}</span>
                  {% else %}
                    <span class="gap">{{ part.title }}</span>
                  {% endif %}
                {% endfor %}

                {% if paginate.next %}
                  <a href="{{ paginate.next.url }}" class="nav-arrow nav-arrow--next" aria-label="Next page">Next <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg></a>
                {% else %}
                  <span class="nav-arrow nav-arrow--next" aria-disabled="true">Next <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg></span>
                {% endif %}
              </nav>
            {% endif %}
          </div>
        </div>
      </form>
      {% endpaginate %}

      {% if show_filters %}
        <div id="chosenhope-filter-drawer-backdrop" class="filter-drawer-backdrop"></div>
        <div id="chosenhope-filter-drawer" class="chosenhope-home-scope filter-drawer" role="dialog" aria-modal="true" aria-label="Filters">
          <div class="filter-drawer-head">
            <h2>Filters</h2>
            <button type="button" class="filter-drawer-close" data-filter-drawer-close aria-label="Close filters">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M6 6l12 12M18 6 6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            </button>
          </div>
          <form method="get" action="{{ collection.url }}">
            {% assign drawer_id_prefix = 'f-drawer' | append: section.id %}
            {% render 'chosenhope-shop-filters', collection: collection, id_prefix: drawer_id_prefix %}
            <button type="submit" class="btn btn-gold filters-apply">Show results</button>
          </form>
        </div>
      {% endif %}
    {% endif %}
  </div>

  {% render 'chosenhope-overlays', section: section %}
</div>
