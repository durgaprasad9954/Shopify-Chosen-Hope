{{ 'chosenhope-base.css' | asset_url | stylesheet_tag }}
{{ 'chosenhope-hero.css' | asset_url | stylesheet_tag }}

<section
  class="chosenhope-home-scope chosenhope-hero"
  aria-labelledby="chosenhope-hero-heading-{{ section.id }}"
  style="
    --ch-hero-bg: {{ section.settings.section_background_color }};
    --ch-hero-overlay-start: {{ section.settings.overlay_color_start }};
    --ch-hero-overlay-mid: {{ section.settings.overlay_color_mid }};
    --ch-hero-overlay-end: {{ section.settings.overlay_color_end }};
    --ch-hero-eyebrow-color: {{ section.settings.eyebrow_color }};
    --ch-hero-heading-color: {{ section.settings.heading_color }};
    --ch-hero-subtext-color: {{ section.settings.subtext_color }};
    {% if section.settings.heading_font_size != blank %}--ch-hero-heading-size: {{ section.settings.heading_font_size }};{% endif %}
    {% if section.settings.heading_font_weight != blank %}--ch-hero-heading-weight: {{ section.settings.heading_font_weight }};{% endif %}
    {% if section.settings.subtext_font_size != blank %}--ch-hero-subtext-size: {{ section.settings.subtext_font_size }};{% endif %}
    {% if section.settings.subtext_font_weight != blank %}--ch-hero-subtext-weight: {{ section.settings.subtext_font_weight }};{% endif %}
  "
>
  <div class="chosenhope-hero__media">
    {% if section.settings.hero_image != blank %}
      <div class="chosenhope-hero__image-wrap">
        {{ section.settings.hero_image | image_url: width: 2200 | image_tag: class: 'media-cover', widths: '750,1100,1500,1800,2200', alt: section.settings.hero_heading }}
      </div>
    {% else %}
      <div class="chosenhope-hero__fallback-wrap">
        <div class="fallback-photo"><span class="fallback-symbol">✦</span></div>
      </div>
    {% endif %}

    <div class="chosenhope-hero__overlay">
      <div class="chosenhope-hero__copy">
        <span class="eyebrow on-dark">{{ section.settings.hero_eyebrow }}</span>
        <h1 id="chosenhope-hero-heading-{{ section.id }}" class="chosenhope-hero__heading">{{ section.settings.hero_heading }}</h1>
        <p class="chosenhope-hero__subtext">{{ section.settings.hero_subtext }}</p>
        <div class="chosenhope-hero__buttons">
          {% if section.settings.hero_primary_label != blank %}
            <a class="btn btn-gold" href="{{ section.settings.hero_primary_url | default: '#' }}">{{ section.settings.hero_primary_label }}</a>
          {% endif %}
          {% if section.settings.hero_secondary_label != blank %}
            <a class="btn btn-outline-light" href="{{ section.settings.hero_secondary_url | default: '#' }}">{{ section.settings.hero_secondary_label }}</a>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "ChosenHope Hero",
  "settings": [
    { "type": "text", "id": "hero_eyebrow", "label": "Hero eyebrow", "default": "ChosenHope collection" },
    { "type": "text", "id": "hero_heading", "label": "Hero heading", "default": "You Are Chosen." },
    { "type": "textarea", "id": "hero_subtext", "label": "Hero subtext", "default": "Cross necklaces, faith jewelry, canvas art, and apparel — made with quiet quality for a life set apart." },
    { "type": "text", "id": "hero_primary_label", "label": "Primary button label", "default": "Shop collection" },
    { "type": "url", "id": "hero_primary_url", "label": "Primary button link" },
    { "type": "text", "id": "hero_secondary_label", "label": "Secondary button label", "default": "Our story" },
    { "type": "url", "id": "hero_secondary_url", "label": "Secondary button link" },
    { "type": "image_picker", "id": "hero_image", "label": "Hero image" },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "section_background_color", "label": "Section background", "default": "#f9f8f4" },
    { "type": "color", "id": "overlay_color_start", "label": "Overlay color (top)", "default": "rgba(23, 22, 20, 0.82)" },
    { "type": "color", "id": "overlay_color_mid", "label": "Overlay color (middle)", "default": "rgba(23, 22, 20, 0.55)" },
    { "type": "color", "id": "overlay_color_end", "label": "Overlay color (bottom accent)", "default": "rgba(200, 162, 74, 0.28)" },
    { "type": "color", "id": "eyebrow_color", "label": "Eyebrow text color", "default": "#c8a24a" },
    { "type": "color", "id": "heading_color", "label": "Heading text color", "default": "#f9f8f4" },
    { "type": "color", "id": "subtext_color", "label": "Subtext color", "default": "rgba(249, 248, 244, 0.86)" },
    { "type": "header", "content": "Typography" },
    {
      "type": "select",
      "id": "heading_font_size",
      "label": "Heading size",
      "options": [
        { "value": "", "label": "Default (responsive)" },
        { "value": "1.75rem", "label": "Small" },
        { "value": "2.5rem", "label": "Medium" },
        { "value": "3.25rem", "label": "Large" },
        { "value": "4rem", "label": "X-Large" },
        { "value": "4.75rem", "label": "XX-Large" }
      ],
      "default": ""
    },
    {
      "type": "select",
      "id": "heading_font_weight",
      "label": "Heading weight",
      "options": [
        { "value": "", "label": "Default" },
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semibold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": ""
    },
    {
      "type": "select",
      "id": "subtext_font_size",
      "label": "Subtext size",
      "options": [
        { "value": "", "label": "Default" },
        { "value": "0.875rem", "label": "Small" },
        { "value": "1rem", "label": "Medium" },
        { "value": "1.125rem", "label": "Large" },
        { "value": "1.25rem", "label": "X-Large" }
      ],
      "default": ""
    },
    {
      "type": "select",
      "id": "subtext_font_weight",
      "label": "Subtext weight",
      "options": [
        { "value": "", "label": "Default" },
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semibold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": ""
    }
  ],
  "presets": [
    { "name": "ChosenHope Hero" }
  ]
}
{% endschema %}
