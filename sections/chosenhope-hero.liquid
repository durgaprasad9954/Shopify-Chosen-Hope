{{ 'chosenhope-base.css' | asset_url | stylesheet_tag }}
{{ 'chosenhope-hero.css' | asset_url | stylesheet_tag }}

<section class="chosenhope-home-scope chosenhope-hero" aria-labelledby="chosenhope-hero-heading-{{ section.id }}">
  <div class="chosenhope-hero__media">
    {% if section.settings.hero_image != blank %}
      <div class="chosenhope-hero__image-wrap">
        {{ section.settings.hero_image | image_url: width: 2200 | image_tag: class: 'media-cover', widths: '750,1100,1500,1800,2200', alt: section.settings.hero_heading }}
      </div>
    {% else %}
      <div class="chosenhope-hero__fallback-wrap">
        <div class="fallback-photo"><span class="fallback-symbol">✦</span></div>
      </div>
    {% endif %}

    <div class="chosenhope-hero__overlay">
      <div class="chosenhope-hero__copy">
        <span class="eyebrow on-dark">{{ section.settings.hero_eyebrow }}</span>
        <h1 id="chosenhope-hero-heading-{{ section.id }}" class="chosenhope-hero__heading">{{ section.settings.hero_heading }}</h1>
        <p class="chosenhope-hero__subtext">{{ section.settings.hero_subtext }}</p>
        <div class="chosenhope-hero__buttons">
          {% if section.settings.hero_primary_label != blank %}
            <a class="btn btn-gold" href="{{ section.settings.hero_primary_url | default: '#' }}">{{ section.settings.hero_primary_label }}</a>
          {% endif %}
          {% if section.settings.hero_secondary_label != blank %}
            <a class="btn btn-outline-light" href="{{ section.settings.hero_secondary_url | default: '#' }}">{{ section.settings.hero_secondary_label }}</a>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "ChosenHope Hero",
  "settings": [
    { "type": "text", "id": "hero_eyebrow", "label": "Hero eyebrow", "default": "ChosenHope collection" },
    { "type": "text", "id": "hero_heading", "label": "Hero heading", "default": "You Are Chosen." },
    { "type": "textarea", "id": "hero_subtext", "label": "Hero subtext", "default": "Cross necklaces, faith jewelry, canvas art, and apparel — made with quiet quality for a life set apart." },
    { "type": "text", "id": "hero_primary_label", "label": "Primary button label", "default": "Shop collection" },
    { "type": "url", "id": "hero_primary_url", "label": "Primary button link" },
    { "type": "text", "id": "hero_secondary_label", "label": "Secondary button label", "default": "Our story" },
    { "type": "url", "id": "hero_secondary_url", "label": "Secondary button link" },
    { "type": "image_picker", "id": "hero_image", "label": "Hero image" }
  ],
  "presets": [
    { "name": "ChosenHope Hero" }
  ]
}
{% endschema %}
