{{ 'chosenhope-base.css' | asset_url | stylesheet_tag }}
{{ 'chosenhope-canvas-feature.css' | asset_url | stylesheet_tag }}

<section class="chosenhope-home-scope chosenhope-canvas-feature" aria-labelledby="chosenhope-canvas-feature-{{ section.id }}">
  <div class="container chosenhope-canvas-feature__layout">
    <div class="chosenhope-canvas-feature__media">
      {% if section.settings.image != blank %}
        {{ section.settings.image | image_url: width: 1200 | image_tag: class: 'media-cover', widths: '480,720,960,1200', alt: section.settings.heading }}
      {% else %}
        <div class="fallback-photo fallback-photo--olive"><span class="fallback-symbol">✚</span></div>
      {% endif %}
      <div class="chosenhope-canvas-feature__badge">{{ section.settings.badge_text }}</div>
    </div>

    <div class="chosenhope-canvas-feature__copy">
      <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      <h2 id="chosenhope-canvas-feature-{{ section.id }}">{{ section.settings.heading }}</h2>
      <p>{{ section.settings.text }}</p>
      <ul class="chosenhope-canvas-feature__list">
        <li><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M4 12l5 5L20 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>{{ section.settings.feature_1 }}</li>
        <li><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M4 12l5 5L20 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>{{ section.settings.feature_2 }}</li>
        <li><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M4 12l5 5L20 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>{{ section.settings.feature_3 }}</li>
      </ul>
      {% if section.settings.button_label != blank %}
        <a class="btn btn-dark" href="{{ section.settings.button_url | default: '#' }}" style="margin-top:2.25rem;">{{ section.settings.button_label }}</a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "ChosenHope Canvas Feature",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "badge_text", "label": "Badge text", "default": "Oak · Walnut · Black frames" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "New from the studio" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Scripture, framed for a modern home" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Each canvas is printed on museum-grade material and finished by hand — a quiet reminder for the wall you look at every day." },
    { "type": "text", "id": "feature_1", "label": "Feature 1", "default": "Room mockup preview before you buy" },
    { "type": "text", "id": "feature_2", "label": "Feature 2", "default": "Three frame finishes, five sizes" },
    { "type": "text", "id": "feature_3", "label": "Feature 3", "default": "Archival ink, fade-resistant for decades" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop Canvas Collection" },
    { "type": "url", "id": "button_url", "label": "Button link" }
  ],
  "presets": [
    { "name": "ChosenHope Canvas Feature" }
  ]
}
{% endschema %}
