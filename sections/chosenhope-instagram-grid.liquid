{{ 'chosenhope-base.css' | asset_url | stylesheet_tag }}
{{ 'chosenhope-instagram-grid.css' | asset_url | stylesheet_tag }}

<section class="chosenhope-home-scope chosenhope-instagram-grid" aria-labelledby="chosenhope-instagram-grid-{{ section.id }}">
  <div class="container">
    <div class="section-head center">
      <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      <h2 id="chosenhope-instagram-grid-{{ section.id }}">{{ section.settings.heading }}</h2>
    </div>

    <div class="chosenhope-instagram-grid__grid">
      {% for block in section.blocks %}
        <a class="chosenhope-instagram-grid__item {% if forloop.first %}chosenhope-instagram-grid__item--big{% endif %}" href="{{ block.settings.link | default: '#' }}" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            {{ block.settings.image | image_url: width: 900 | image_tag: class: 'media-cover', widths: '220,440,660,900', alt: block.settings.alt_text | default: shop.name }}
          {% else %}
            <div class="fallback-photo {% cycle 'fallback-photo--sand', 'fallback-photo--olive', 'fallback-photo--gold', 'fallback-photo--cream', '' %}"><span class="fallback-symbol">+</span></div>
          {% endif %}
          <span class="chosenhope-instagram-grid__icon">◎</span>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "ChosenHope Instagram",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "@chosenhope" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Follow along" }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Tile",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "url", "id": "link", "label": "Link" },
        { "type": "text", "id": "alt_text", "label": "Alt text" }
      ]
    }
  ],
  "presets": [
    {
      "name": "ChosenHope Instagram",
      "blocks": [
        { "type": "tile" },
        { "type": "tile" },
        { "type": "tile" },
        { "type": "tile" },
        { "type": "tile" }
      ]
    }
  ]
}
{% endschema %}
