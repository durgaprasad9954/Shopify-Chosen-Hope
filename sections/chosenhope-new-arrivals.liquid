{{ 'chosenhope-base.css' | asset_url | stylesheet_tag }}
{{ 'chosenhope-new-arrivals.css' | asset_url | stylesheet_tag }}

<section
  class="chosenhope-home-scope chosenhope-new-arrivals"
  aria-labelledby="chosenhope-new-arrivals-{{ section.id }}"
  style="
    --ch-na-bg: {{ section.settings.section_background_color }};
    --ch-na-eyebrow-color: {{ section.settings.eyebrow_color }};
    --ch-na-heading-color: {{ section.settings.heading_color }};
    --ch-na-badge-bg: {{ section.settings.badge_background_color }};
    --ch-na-badge-text: {{ section.settings.badge_text_color }};
    --ch-na-card-title: {{ section.settings.card_title_color }};
  "
>
  <div class="container">
    <div class="section-top">
      <div>
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
        <h2 id="chosenhope-new-arrivals-{{ section.id }}">{{ section.settings.heading }}</h2>
      </div>
    </div>

    <div class="chosenhope-new-arrivals__track">
      {% if section.settings.collection != blank %}
        {% for product in section.settings.collection.products limit: section.settings.limit %}
          <article class="chosenhope-new-arrivals__card">
            <div class="chosenhope-new-arrivals__media">
              <span class="chosenhope-new-arrivals__badge">{{ section.settings.badge_text }}</span>
              {% if product.featured_media != blank %}
                {{ product.featured_media | image_url: width: 500 | image_tag: class: 'media-cover', widths: '320,500,700', sizes: '250px', alt: product.title }}
              {% else %}
                <div class="fallback-photo fallback-photo--sand"><span class="fallback-symbol">+</span></div>
              {% endif %}
            </div>
            <div class="chosenhope-new-arrivals__info">
              <h4>{{ product.title }}</h4>
              <span class="product-price">{{ product.price | money }}</span>
            </div>
          </article>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "ChosenHope New Arrivals",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Just added" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "New arrivals" },
    { "type": "text", "id": "badge_text", "label": "Badge text", "default": "New" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "limit", "label": "Products to show", "min": 3, "max": 8, "step": 1, "default": 5 },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "section_background_color", "label": "Section background", "default": "#ffffff" },
    { "type": "color", "id": "eyebrow_color", "label": "Eyebrow text color", "default": "#6e7455" },
    { "type": "color", "id": "heading_color", "label": "Heading text color", "default": "#111111" },
    { "type": "color", "id": "badge_background_color", "label": "Badge background", "default": "#ffffff" },
    { "type": "color", "id": "badge_text_color", "label": "Badge text color", "default": "#111111" },
    { "type": "color", "id": "card_title_color", "label": "Product title color", "default": "#111111" }
  ],
  "presets": [
    { "name": "ChosenHope New Arrivals" }
  ]
}
{% endschema %}
