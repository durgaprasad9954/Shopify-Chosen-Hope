{{ 'chosenhope-base.css' | asset_url | stylesheet_tag }}
{{ 'chosenhope-shop-hero.css' | asset_url | stylesheet_tag }}

<div
  class="chosenhope-home-scope chosenhope-shop-hero"
  style="
    --ch-sh-gradient-start: {{ section.settings.gradient_start_color }};
    --ch-sh-gradient-end: {{ section.settings.gradient_end_color }};
    --ch-sh-eyebrow-color: {{ section.settings.eyebrow_color }};
    --ch-sh-heading-color: {{ section.settings.heading_color }};
    --ch-sh-text-color: {{ section.settings.text_color }};
  "
>
  <div class="container">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}">Home</a>
      <span aria-hidden="true">/</span>
      <span aria-current="page">{{ section.settings.breadcrumb_label }}</span>
    </nav>

    <section class="page-hero" aria-labelledby="chosenhope-shop-hero-heading-{{ section.id }}" style="background: linear-gradient(160deg, var(--ch-sh-gradient-start) 0%, var(--ch-sh-gradient-end) 60%);">
      <div>
        <span class="eyebrow" style="color: var(--ch-sh-eyebrow-color);">{{ section.settings.eyebrow }}</span>
        <h1 id="chosenhope-shop-hero-heading-{{ section.id }}" style="color: var(--ch-sh-heading-color);">{{ section.settings.heading }}</h1>
        <p style="color: var(--ch-sh-text-color);">{{ section.settings.subtext }}</p>
      </div>
      <div class="page-hero-art">
        <div class="fallback-photo">
          <div class="photo-art">
            {% case section.settings.icon %}
              {% when 'cross' %}
                <svg width="55%" height="55%" viewBox="0 0 200 200" fill="none" aria-hidden="true"><path d="M100 30c60 75 100 88 80 88" stroke="var(--ch-warm-white)" stroke-width="1" opacity="0.45"/><path d="M100 100v50M80 118h40" stroke="var(--ch-gold)" stroke-width="2.6" stroke-linecap="round"/><circle cx="100" cy="100" r="2.4" fill="var(--ch-gold)"/></svg>
              {% when 'star' %}
                <svg width="60%" height="60%" viewBox="0 0 200 200" fill="none" aria-hidden="true"><path d="M100 40l14 30 33 5-24 23 6 33-29-15-29 15 6-33-24-23 33-5 14-30Z" stroke="var(--ch-gold)" stroke-width="1.4"/></svg>
              {% when 'canvas' %}
                <svg width="45%" height="45%" viewBox="0 0 100 100" fill="none" aria-hidden="true"><rect x="30" y="22" width="40" height="54" rx="1" stroke="var(--ch-ink)" stroke-width="1.3"/><path d="M40 60c6-14 14-14 20 0" stroke="var(--ch-gold)" stroke-width="1.2"/></svg>
              {% when 'apparel' %}
                <svg width="55%" height="55%" viewBox="0 0 100 100" fill="none" aria-hidden="true"><path d="M35 22l-15 9v11h8v36h44V42h8V31l-15-9-8 5h-14z" stroke="var(--ch-gold)" stroke-width="1.3"/></svg>
              {% when 'crosshair' %}
                <svg width="55%" height="55%" viewBox="0 0 200 200" fill="none" aria-hidden="true"><path d="M100 30v140M30 100h140" stroke="var(--ch-gold)" stroke-width="1.4"/><circle cx="100" cy="100" r="55" stroke="var(--ch-warm-white)" stroke-width="0.8" opacity="0.5"/></svg>
            {% endcase %}
          </div>
        </div>
      </div>
    </section>
  </div>
</div>

{% schema %}
{
  "name": "ChosenHope Shop Hero",
  "settings": [
    { "type": "text", "id": "breadcrumb_label", "label": "Breadcrumb / page label", "default": "Shop" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Wear it close" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Faith Jewelry" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Rings, chains, and bracelets made to be worn every day — a quiet reminder close to the skin." },
    {
      "type": "select",
      "id": "icon",
      "label": "Decorative icon",
      "options": [
        { "value": "cross", "label": "Cross (Jewelry)" },
        { "value": "star", "label": "Star (Best Sellers)" },
        { "value": "canvas", "label": "Framed canvas (Canvas)" },
        { "value": "apparel", "label": "Hoodie (Apparel)" },
        { "value": "crosshair", "label": "Crosshair (Collections)" }
      ],
      "default": "cross"
    },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "gradient_start_color", "label": "Gradient start", "default": "#f3e9d3" },
    { "type": "color", "id": "gradient_end_color", "label": "Gradient end", "default": "#f9f8f4" },
    { "type": "color", "id": "eyebrow_color", "label": "Eyebrow color", "default": "#6e7455" },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#111111" },
    { "type": "color", "id": "text_color", "label": "Subtext color", "default": "#666666" }
  ],
  "enabled_on": {
    "templates": ["collection"]
  },
  "presets": [
    { "name": "ChosenHope Shop Hero" }
  ]
}
{% endschema %}
