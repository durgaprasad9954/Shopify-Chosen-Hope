{{ 'chosenhope-home.css' | asset_url | stylesheet_tag }}

{% liquid
  assign reviews = section.blocks | where: 'type', 'review'
  assign instagram_tiles = section.blocks | where: 'type', 'instagram_tile'
  assign header_menu = linklists[section.settings.header_menu]
  assign footer_shop_menu = linklists[section.settings.footer_shop_menu]
  assign footer_support_menu = linklists[section.settings.footer_support_menu]
  assign footer_company_menu = linklists[section.settings.footer_company_menu]
  assign footer_legal_menu = linklists[section.settings.footer_legal_menu]
%}

{% capture chosenhope_logo %}
  {% if settings.logo != blank %}
    {{
      settings.logo
      | image_url: width: 420
      | image_tag:
        widths: '160, 240, 320, 420',
        alt: shop.name
    }}
  {% else %}
    <h3>{{ shop.name }}</h3>
  {% endif %}
{% endcapture %}

<div class="chosenhope-home" data-chosenhope-home>
  <div class="announce" role="note">
    {{ section.settings.announcement_text }}
    {% if section.settings.announcement_emphasis != blank %}
      &nbsp;&middot;&nbsp; <strong>{{ section.settings.announcement_emphasis }}</strong>
    {% endif %}
  </div>

  <header class="site-header">
    <div class="container header-row">
      <a class="logo-lockup" href="{{ routes.root_url }}" aria-label="{{ shop.name }}, home">
        <div class="header-logo">{{ chosenhope_logo }}</div>
      </a>
      <nav class="main-nav" aria-label="Primary">
        <ul>
          {% for link in header_menu.links %}
            <li class="{% if link.links != blank %}has-mega{% endif %}">
              <a href="{{ link.url }}">{{ link.title }}</a>
              {% if link.links != blank %}
                <div class="mega">
                  <div class="mega-head">{{ link.title }}</div>
                  {% for child in link.links %}
                    <a href="{{ child.url }}">{{ child.title }}</a>
                  {% endfor %}
                </div>
              {% endif %}
            </li>
          {% endfor %}
        </ul>
      </nav>
      <div class="header-actions">
        <details class="mobile-nav-wrap">
          <summary class="icon-btn mobile-nav-summary" aria-label="Open menu">☰</summary>
          <nav class="mobile-nav" id="chosenhope-mobile-nav-{{ section.id }}" aria-label="Mobile">
            {% for link in header_menu.links %}
              <a href="{{ link.url }}">{{ link.title }}</a>
              {% for child in link.links %}
                <a href="{{ child.url }}">{{ child.title }}</a>
              {% endfor %}
            {% endfor %}
          </nav>
        </details>
        <a class="icon-btn" href="{{ routes.search_url }}" aria-label="Search">⌕</a>
        <a class="icon-btn" href="{{ routes.account_url }}" aria-label="Account">◌</a>
        <a class="icon-btn" href="{{ routes.cart_url }}" aria-label="Cart">
          ◧
          {% if cart.item_count > 0 %}
            <span class="badge">{{ cart.item_count }}</span>
          {% endif %}
        </a>
      </div>
    </div>
  </header>

  <main>
    <section class="hero" aria-labelledby="chosenhope-hero-{{ section.id }}">
      <div class="hero-media">
        {% if section.settings.hero_image != blank %}
          <div class="hero-image-wrap">
            {{ section.settings.hero_image | image_url: width: 2200 | image_tag: class: 'hero-image', widths: '750, 1100, 1500, 1800, 2200', alt: section.settings.hero_heading }}
          </div>
        {% else %}
          <div class="fallback-wrap"><div class="fallback-photo"><span class="fallback-symbol">✦</span></div></div>
        {% endif %}
        <div class="hero-overlay">
          <div class="hero-copy">
            <span class="eyebrow on-dark">{{ section.settings.hero_eyebrow }}</span>
            <h1 id="chosenhope-hero-{{ section.id }}">{{ section.settings.hero_heading }}</h1>
            <p class="hero-sub">{{ section.settings.hero_subtext }}</p>
            <div class="hero-ctas">
              {% if section.settings.hero_primary_label != blank %}
                <a class="btn btn-gold" href="{{ section.settings.hero_primary_url | default: '#' }}">{{ section.settings.hero_primary_label }}</a>
              {% endif %}
              {% if section.settings.hero_secondary_label != blank %}
                <a class="btn btn-outline-light" href="{{ section.settings.hero_secondary_url | default: '#' }}">{{ section.settings.hero_secondary_label }}</a>
              {% endif %}
            </div>
          </div>
        </div>
      </div>
    </section>

    <section aria-labelledby="chosenhope-collections-{{ section.id }}">
      <div class="container">
        <div class="section-head center reveal">
          <span class="eyebrow">{{ section.settings.featured_collections_eyebrow }}</span>
          <h2 id="chosenhope-collections-{{ section.id }}">{{ section.settings.featured_collections_heading }}</h2>
          <p>{{ section.settings.featured_collections_subtext }}</p>
        </div>
        {% assign fc1 = section.settings.featured_collection_1 %}
        {% assign fc2 = section.settings.featured_collection_2 %}
        {% assign fc3 = section.settings.featured_collection_3 %}
        {% assign fc4 = section.settings.featured_collection_4 %}
        <div class="bento reveal">
          {% if fc1 != blank %}
            <a class="bento-item" href="{{ fc1.url }}">{% if fc1.featured_image != blank %}{{ fc1.featured_image | image_url: width: 1200 | image_tag: class: 'media-cover', widths: '400, 600, 900, 1200', alt: fc1.title }}{% else %}<div class="fallback-photo fallback-photo--olive"><span class="fallback-symbol">+</span></div>{% endif %}<div class="bento-scrim"></div><div class="bento-label"><h3>{{ fc1.title }}</h3></div></a>
          {% endif %}
          {% if fc2 != blank %}
            <a class="bento-item" href="{{ fc2.url }}">{% if fc2.featured_image != blank %}{{ fc2.featured_image | image_url: width: 1200 | image_tag: class: 'media-cover', widths: '400, 600, 900, 1200', alt: fc2.title }}{% else %}<div class="fallback-photo fallback-photo--sand"><span class="fallback-symbol">+</span></div>{% endif %}<div class="bento-scrim"></div><div class="bento-label"><h3>{{ fc2.title }}</h3></div></a>
          {% endif %}
          {% if fc3 != blank %}
            <a class="bento-item" href="{{ fc3.url }}">{% if fc3.featured_image != blank %}{{ fc3.featured_image | image_url: width: 1200 | image_tag: class: 'media-cover', widths: '400, 600, 900, 1200', alt: fc3.title }}{% else %}<div class="fallback-photo fallback-photo--gold"><span class="fallback-symbol">+</span></div>{% endif %}<div class="bento-scrim"></div><div class="bento-label"><h3>{{ fc3.title }}</h3></div></a>
          {% endif %}
          {% if fc4 != blank %}
            <a class="bento-item" href="{{ fc4.url }}">{% if fc4.featured_image != blank %}{{ fc4.featured_image | image_url: width: 1200 | image_tag: class: 'media-cover', widths: '400, 600, 900, 1200', alt: fc4.title }}{% else %}<div class="fallback-photo fallback-photo--cream"><span class="fallback-symbol">+</span></div>{% endif %}<div class="bento-scrim"></div><div class="bento-label"><h3>{{ fc4.title }}</h3></div></a>
          {% endif %}
        </div>
      </div>
    </section>

    <section aria-labelledby="chosenhope-best-{{ section.id }}" style="background:var(--ch-white);">
      <div class="container">
        <div class="section-top reveal">
          <div>
            <span class="eyebrow">{{ section.settings.best_sellers_eyebrow }}</span>
            <h2 id="chosenhope-best-{{ section.id }}">{{ section.settings.best_sellers_heading }}</h2>
          </div>
        </div>
        <div class="editorial-grid reveal">
          {% assign featured_product = section.settings.featured_product %}
          <a class="editorial-feature" href="{{ featured_product.url | default: '#' }}">
            {% if featured_product.featured_media != blank %}
              {{ featured_product.featured_media | image_url: width: 1200 | image_tag: class: 'media-cover', widths: '480, 720, 960, 1200', alt: featured_product.title }}
            {% else %}
              <div class="fallback-photo fallback-photo--sand"><span class="fallback-symbol">✦</span></div>
            {% endif %}
            <div class="editorial-scrim"></div>
            <span class="editorial-badge">{{ section.settings.featured_product_badge }}</span>
            <div class="editorial-feature-copy">
              <div>
                <h3>{{ featured_product.title | default: 'Grace Cross Necklace' }}</h3>
                <span class="product-price">{{ featured_product.price | money | default: '$68.00' }}</span>
              </div>
              <span class="stars">★★★★★</span>
            </div>
          </a>
          {% assign ep1 = section.settings.editorial_product_1 %}
          {% assign ep2 = section.settings.editorial_product_2 %}
          {% assign ep3 = section.settings.editorial_product_3 %}
          {% assign ep4 = section.settings.editorial_product_4 %}
          <div class="editorial-list">
            {% if ep1 != blank %}<a class="editorial-row" href="{{ ep1.url }}"><div class="thumb">{% if ep1.featured_media != blank %}{{ ep1.featured_media | image_url: width: 240 | image_tag: class: 'media-cover', widths: '120, 180, 240', alt: ep1.title }}{% else %}<div class="fallback-photo fallback-photo--gold"><span class="fallback-symbol">+</span></div>{% endif %}</div><div class="info"><h4>{{ ep1.title }}</h4><div class="meta"><span class="stars">★★★★★</span><span class="product-price">{{ ep1.price | money }}</span></div></div></a>{% endif %}
            {% if ep2 != blank %}<a class="editorial-row" href="{{ ep2.url }}"><div class="thumb">{% if ep2.featured_media != blank %}{{ ep2.featured_media | image_url: width: 240 | image_tag: class: 'media-cover', widths: '120, 180, 240', alt: ep2.title }}{% else %}<div class="fallback-photo fallback-photo--olive"><span class="fallback-symbol">+</span></div>{% endif %}</div><div class="info"><h4>{{ ep2.title }}</h4><div class="meta"><span class="stars">★★★★★</span><span class="product-price">{{ ep2.price | money }}</span></div></div></a>{% endif %}
            {% if ep3 != blank %}<a class="editorial-row" href="{{ ep3.url }}"><div class="thumb">{% if ep3.featured_media != blank %}{{ ep3.featured_media | image_url: width: 240 | image_tag: class: 'media-cover', widths: '120, 180, 240', alt: ep3.title }}{% else %}<div class="fallback-photo fallback-photo--sand"><span class="fallback-symbol">+</span></div>{% endif %}</div><div class="info"><h4>{{ ep3.title }}</h4><div class="meta"><span class="stars">★★★★★</span><span class="product-price">{{ ep3.price | money }}</span></div></div></a>{% endif %}
            {% if ep4 != blank %}<a class="editorial-row" href="{{ ep4.url }}"><div class="thumb">{% if ep4.featured_media != blank %}{{ ep4.featured_media | image_url: width: 240 | image_tag: class: 'media-cover', widths: '120, 180, 240', alt: ep4.title }}{% else %}<div class="fallback-photo fallback-photo--cream"><span class="fallback-symbol">+</span></div>{% endif %}</div><div class="info"><h4>{{ ep4.title }}</h4><div class="meta"><span class="stars">★★★★★</span><span class="product-price">{{ ep4.price | money }}</span></div></div></a>{% endif %}
          </div>
        </div>
      </div>
    </section>

    {% liquid
      assign category_top = section.settings.category_collection_top
      assign category_left_outer = section.settings.category_collection_left_outer
      assign category_left_inner = section.settings.category_collection_left_inner
      assign category_center = section.settings.category_collection_center
      assign category_right_inner = section.settings.category_collection_right_inner
      assign category_right_outer = section.settings.category_collection_right_outer
      assign category_bottom = section.settings.category_collection_bottom
      assign category_bottom_2 = section.settings.category_collection_bottom_2
      assign category_title_top = section.settings.category_title_top | default: category_top.title | default: 'Canvas Prints'
      assign category_title_left_outer = section.settings.category_title_left_outer | default: category_left_outer.title | default: 'Caps'
      assign category_title_left_inner = section.settings.category_title_left_inner | default: category_left_inner.title | default: 'Rings'
      assign category_title_center = section.settings.category_title_center | default: category_center.title | default: 'Necklaces'
      assign category_title_right_inner = section.settings.category_title_right_inner | default: category_right_inner.title | default: 'Bracelets'
      assign category_title_right_outer = section.settings.category_title_right_outer | default: category_right_outer.title | default: 'Hoodies & Tees'
      assign category_title_bottom = section.settings.category_title_bottom | default: category_bottom.title | default: 'Wall Art'
      assign category_title_bottom_2 = section.settings.category_title_bottom_2 | default: category_bottom_2.title | default: 'Future Christian Products'
    %}
    <section aria-labelledby="chosenhope-categories-{{ section.id }}">
      <div class="container">
        <div class="section-head center reveal">
          <span class="eyebrow">{{ section.settings.categories_eyebrow }}</span>
          <h2 id="chosenhope-categories-{{ section.id }}">{{ section.settings.categories_heading }}</h2>
        </div>
        <div class="cat-row-desktop reveal">
          <div class="cross-bar-v" aria-hidden="true"></div>
          <div class="cross-bar-h" aria-hidden="true"></div>
          <a class="cat-tile pos-top" href="{{ category_top.url | default: '#' }}"><div class="cat-circle">{% if category_top.featured_image != blank %}{{ category_top.featured_image | image_url: width: 480 | image_tag: class: 'media-cover', widths: '240, 360, 480', alt: category_title_top }}{% else %}<div class="fallback-photo fallback-photo--olive"><span class="fallback-symbol">+</span></div>{% endif %}</div><h3>{{ category_title_top }}</h3></a>
          <a class="cat-tile pos-left-outer" href="{{ category_left_outer.url | default: '#' }}"><div class="cat-circle">{% if category_left_outer.featured_image != blank %}{{ category_left_outer.featured_image | image_url: width: 480 | image_tag: class: 'media-cover', widths: '240, 360, 480', alt: category_title_left_outer }}{% else %}<div class="fallback-photo fallback-photo--cream"><span class="fallback-symbol">+</span></div>{% endif %}</div><h3>{{ category_title_left_outer }}</h3></a>
          <a class="cat-tile pos-left-inner" href="{{ category_left_inner.url | default: '#' }}"><div class="cat-circle">{% if category_left_inner.featured_image != blank %}{{ category_left_inner.featured_image | image_url: width: 480 | image_tag: class: 'media-cover', widths: '240, 360, 480', alt: category_title_left_inner }}{% else %}<div class="fallback-photo fallback-photo--olive"><span class="fallback-symbol">+</span></div>{% endif %}</div><h3>{{ category_title_left_inner }}</h3></a>
          <a class="cat-tile pos-center" href="{{ category_center.url | default: '#' }}"><div class="cat-circle">{% if category_center.featured_image != blank %}{{ category_center.featured_image | image_url: width: 480 | image_tag: class: 'media-cover', widths: '240, 360, 480', alt: category_title_center }}{% else %}<div class="fallback-photo fallback-photo--sand"><span class="fallback-symbol">+</span></div>{% endif %}</div><h3>{{ category_title_center }}</h3></a>
          <a class="cat-tile pos-right-inner" href="{{ category_right_inner.url | default: '#' }}"><div class="cat-circle">{% if category_right_inner.featured_image != blank %}{{ category_right_inner.featured_image | image_url: width: 480 | image_tag: class: 'media-cover', widths: '240, 360, 480', alt: category_title_right_inner }}{% else %}<div class="fallback-photo fallback-photo--gold"><span class="fallback-symbol">+</span></div>{% endif %}</div><h3>{{ category_title_right_inner }}</h3></a>
          <a class="cat-tile pos-right-outer" href="{{ category_right_outer.url | default: '#' }}"><div class="cat-circle">{% if category_right_outer.featured_image != blank %}{{ category_right_outer.featured_image | image_url: width: 480 | image_tag: class: 'media-cover', widths: '240, 360, 480', alt: category_title_right_outer }}{% else %}<div class="fallback-photo"><span class="fallback-symbol">+</span></div>{% endif %}</div><h3>{{ category_title_right_outer }}</h3></a>
          <a class="cat-tile pos-bottom" href="{{ category_bottom.url | default: '#' }}"><div class="cat-circle">{% if category_bottom.featured_image != blank %}{{ category_bottom.featured_image | image_url: width: 480 | image_tag: class: 'media-cover', widths: '240, 360, 480', alt: category_title_bottom }}{% else %}<div class="fallback-photo"><span class="fallback-symbol">+</span></div>{% endif %}</div><h3>{{ category_title_bottom }}</h3></a>
          <a class="cat-tile pos-bottom-2" href="{{ category_bottom_2.url | default: '#' }}"><div class="cat-circle">{% if category_bottom_2.featured_image != blank %}{{ category_bottom_2.featured_image | image_url: width: 480 | image_tag: class: 'media-cover', widths: '240, 360, 480', alt: category_title_bottom_2 }}{% else %}<div class="fallback-photo fallback-photo--cream"><span class="fallback-symbol">+</span></div>{% endif %}</div><h3>{{ category_title_bottom_2 }}</h3></a>
        </div>
        <div class="cat-row-mobile reveal">
          <div class="cross-bar-v" aria-hidden="true"></div>
          <div class="cross-bar-h" aria-hidden="true"></div>
          <a class="cat-tile pos-top" href="{{ category_top.url | default: '#' }}"><div class="cat-circle">{% if category_top.featured_image != blank %}{{ category_top.featured_image | image_url: width: 480 | image_tag: class: 'media-cover', widths: '240, 360, 480', alt: category_title_top }}{% else %}<div class="fallback-photo fallback-photo--olive"><span class="fallback-symbol">+</span></div>{% endif %}</div><h3>{{ category_title_top }}</h3></a>
          <a class="cat-tile pos-left" href="{{ category_left_outer.url | default: '#' }}"><div class="cat-circle">{% if category_left_outer.featured_image != blank %}{{ category_left_outer.featured_image | image_url: width: 480 | image_tag: class: 'media-cover', widths: '240, 360, 480', alt: category_title_left_outer }}{% else %}<div class="fallback-photo fallback-photo--cream"><span class="fallback-symbol">+</span></div>{% endif %}</div><h3>{{ category_title_left_outer }}</h3></a>
          <a class="cat-tile pos-center" href="{{ category_center.url | default: '#' }}"><div class="cat-circle">{% if category_center.featured_image != blank %}{{ category_center.featured_image | image_url: width: 480 | image_tag: class: 'media-cover', widths: '240, 360, 480', alt: section.settings.category_title_mobile_center }}{% else %}<div class="fallback-photo fallback-photo--sand"><span class="fallback-symbol">+</span></div>{% endif %}</div><h3>{{ section.settings.category_title_mobile_center }}</h3></a>
          <a class="cat-tile pos-right" href="{{ category_right_outer.url | default: '#' }}"><div class="cat-circle">{% if category_right_outer.featured_image != blank %}{{ category_right_outer.featured_image | image_url: width: 480 | image_tag: class: 'media-cover', widths: '240, 360, 480', alt: category_title_right_outer }}{% else %}<div class="fallback-photo"><span class="fallback-symbol">+</span></div>{% endif %}</div><h3>{{ category_title_right_outer }}</h3></a>
          <a class="cat-tile pos-below" href="{{ category_bottom.url | default: '#' }}"><div class="cat-circle">{% if category_bottom.featured_image != blank %}{{ category_bottom.featured_image | image_url: width: 480 | image_tag: class: 'media-cover', widths: '240, 360, 480', alt: category_title_bottom }}{% else %}<div class="fallback-photo"><span class="fallback-symbol">+</span></div>{% endif %}</div><h3>{{ category_title_bottom }}</h3></a>
          <a class="cat-tile pos-bottom" href="{{ category_bottom_2.url | default: '#' }}"><div class="cat-circle">{% if category_bottom_2.featured_image != blank %}{{ category_bottom_2.featured_image | image_url: width: 480 | image_tag: class: 'media-cover', widths: '240, 360, 480', alt: category_title_bottom_2 }}{% else %}<div class="fallback-photo fallback-photo--cream"><span class="fallback-symbol">+</span></div>{% endif %}</div><h3>{{ category_title_bottom_2 }}</h3></a>
        </div>
      </div>
    </section>

    <section class="canvas-section" aria-labelledby="chosenhope-canvas-{{ section.id }}">
      <div class="container canvas-layout">
        <div class="canvas-media reveal">
          {% if section.settings.canvas_image != blank %}
            {{ section.settings.canvas_image | image_url: width: 1200 | image_tag: class: 'media-cover', widths: '480, 720, 960, 1200', alt: section.settings.canvas_heading }}
          {% else %}
            <div class="fallback-photo fallback-photo--olive"><span class="fallback-symbol">✚</span></div>
          {% endif %}
          <div class="canvas-frame-badge">Oak &middot; Walnut &middot; Black frames</div>
        </div>
        <div class="canvas-copy reveal">
          <span class="eyebrow">{{ section.settings.canvas_eyebrow }}</span>
          <h2 id="chosenhope-canvas-{{ section.id }}">{{ section.settings.canvas_heading }}</h2>
          <p>{{ section.settings.canvas_text }}</p>
          <ul class="canvas-features">
            <li><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M4 12l5 5L20 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>{{ section.settings.canvas_feature_1 }}</li>
            <li><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M4 12l5 5L20 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>{{ section.settings.canvas_feature_2 }}</li>
            <li><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M4 12l5 5L20 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>{{ section.settings.canvas_feature_3 }}</li>
          </ul>
          {% if section.settings.canvas_button_label != blank %}
            <a class="btn btn-dark" href="{{ section.settings.canvas_button_url | default: '#' }}" style="margin-top:2.25rem;">{{ section.settings.canvas_button_label }}</a>
          {% endif %}
        </div>
      </div>
    </section>

    <section aria-labelledby="chosenhope-new-{{ section.id }}" style="background:var(--ch-white);">
      <div class="container">
        <div class="section-top reveal">
          <div>
            <span class="eyebrow">{{ section.settings.new_arrivals_eyebrow }}</span>
            <h2 id="chosenhope-new-{{ section.id }}">{{ section.settings.new_arrivals_heading }}</h2>
          </div>
        </div>
        <div class="reveal">
          <div class="carousel-track" id="chosenhope-track-{{ section.id }}">
            {% if section.settings.new_arrivals_collection != blank %}
              {% for product in section.settings.new_arrivals_collection.products limit: section.settings.new_arrivals_limit %}
                <article class="product-card">
                  <div class="product-media">
                    <span class="product-badge">New</span>
                    {% if product.featured_media != blank %}
                      {{ product.featured_media | image_url: width: 700 | image_tag: class: 'media-cover', widths: '320, 500, 700', alt: product.title }}
                    {% else %}
                      <div class="fallback-photo fallback-photo--sand"><span class="fallback-symbol">+</span></div>
                    {% endif %}
                  </div>
                  <div class="product-info">
                    <h4>{{ product.title }}</h4>
                    <span class="product-price">{{ product.price | money }}</span>
                  </div>
                </article>
              {% endfor %}
            {% endif %}
          </div>
        </div>
      </div>
    </section>

    <section class="lifestyle-section" aria-labelledby="chosenhope-life-{{ section.id }}">
      <div class="lifestyle-bg">
        {% if section.settings.lifestyle_image != blank %}
          {{ section.settings.lifestyle_image | image_url: width: 2200 | image_tag: class: 'media-cover', widths: '750, 1100, 1500, 1800, 2200', alt: section.settings.lifestyle_quote }}
        {% else %}
          <div class="fallback-photo"><span class="fallback-symbol">✦</span></div>
        {% endif %}
      </div>
      <div class="container lifestyle-content reveal">
        <span class="eyebrow on-dark" id="chosenhope-life-{{ section.id }}">{{ section.settings.lifestyle_eyebrow }}</span>
        <p class="lifestyle-quote">{{ section.settings.lifestyle_quote }}</p>
        <p class="support">{{ section.settings.lifestyle_support }}</p>
        {% if section.settings.lifestyle_button_label != blank %}
          <a class="btn btn-outline-light" href="{{ section.settings.lifestyle_button_url | default: '#' }}">{{ section.settings.lifestyle_button_label }}</a>
        {% endif %}
      </div>
    </section>

    <section aria-labelledby="chosenhope-reviews-{{ section.id }}">
      <div class="container">
        <div class="section-head center reveal">
          <span class="eyebrow">{{ section.settings.reviews_eyebrow }}</span>
          <h2 id="chosenhope-reviews-{{ section.id }}">{{ section.settings.reviews_heading }}</h2>
        </div>
      </div>
      <div class="testi-marquee-wrap reveal">
        <div class="testi-track">
          {% for _dup in (1..2) %}
            {% for review in reviews %}
              <div class="testi-card" {{ review.shopify_attributes }}>
                <div class="testi-stars">{{ review.settings.stars }}</div>
                <p class="testi-quote">&ldquo;{{ review.settings.quote }}&rdquo;</p>
                <p class="testi-name">{{ review.settings.name }}</p>
              </div>
            {% endfor %}
          {% endfor %}
        </div>
      </div>
    </section>

    <section aria-labelledby="chosenhope-instagram-{{ section.id }}" style="background:var(--ch-white);">
      <div class="container">
        <div class="section-head center reveal">
          <span class="eyebrow">{{ section.settings.instagram_eyebrow }}</span>
          <h2 id="chosenhope-instagram-{{ section.id }}">{{ section.settings.instagram_heading }}</h2>
        </div>
        <div class="insta-grid reveal">
          {% for tile in instagram_tiles %}
            <a class="insta-tile {% if forloop.first %}big{% endif %}" href="{{ tile.settings.link | default: '#' }}" {{ tile.shopify_attributes }}>
              {% if tile.settings.image != blank %}
                {{ tile.settings.image | image_url: width: 900 | image_tag: class: 'media-cover', widths: '220, 440, 660, 900', alt: tile.settings.alt_text | default: shop.name }}
              {% else %}
                <div class="fallback-photo {% cycle 'fallback-photo--sand', 'fallback-photo--olive', 'fallback-photo--gold', 'fallback-photo--cream', '' %}"><span class="fallback-symbol">+</span></div>
              {% endif %}
              <span class="icon">◎</span>
            </a>
          {% endfor %}
        </div>
      </div>
    </section>

    <section>
      <div class="container">
        <div class="newsletter-split reveal">
          <div class="newsletter-photo">
            {% if section.settings.newsletter_image != blank %}
              {{ section.settings.newsletter_image | image_url: width: 1200 | image_tag: class: 'media-cover', widths: '420, 720, 960, 1200', alt: section.settings.newsletter_heading }}
            {% else %}
              <div class="fallback-photo fallback-photo--olive"><span class="fallback-symbol">✚</span></div>
            {% endif %}
          </div>
          <div class="newsletter-form-panel">
            <h2>{{ section.settings.newsletter_heading }}</h2>
            <p>{{ section.settings.newsletter_text }}</p>
            {% form 'customer', class: 'newsletter-form' %}
              <input type="hidden" name="contact[tags]" value="newsletter">
              <div class="field-group">
                <label for="chosenhope-newsletter-{{ section.id }}">Email address</label>
                <input id="chosenhope-newsletter-{{ section.id }}" type="email" name="contact[email]" value="{{ form.email }}" placeholder="you@example.com" required>
              </div>
              <button class="btn btn-gold" type="submit" style="align-self:flex-end;">{{ section.settings.newsletter_button_label }}</button>
              {% if form.posted_successfully? %}
                <p class="newsletter-note newsletter-note--success">Thanks for subscribing.</p>
              {% endif %}
              {% if form.errors %}
                <ul class="newsletter-errors">
                  {% for field in form.errors %}
                    <li>{{ form.errors.messages[field] }}</li>
                  {% endfor %}
                </ul>
              {% endif %}
            {% endform %}
            <p class="newsletter-note">{{ section.settings.newsletter_privacy_text }}</p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="container footer-grid">
      <div class="footer-brand">
        <div class="footer-logo">{{ chosenhope_logo }}</div>
        <p>{{ section.settings.footer_brand_text }}</p>
        <div class="footer-social">
          {% if section.settings.social_instagram != blank %}<a href="{{ section.settings.social_instagram }}" aria-label="Instagram">IG</a>{% endif %}
          {% if section.settings.social_pinterest != blank %}<a href="{{ section.settings.social_pinterest }}" aria-label="Pinterest">P</a>{% endif %}
          {% if section.settings.social_facebook != blank %}<a href="{{ section.settings.social_facebook }}" aria-label="Facebook">f</a>{% endif %}
        </div>
      </div>
      <div class="footer-col"><h3>Shop</h3><ul>{% for link in footer_shop_menu.links %}<li><a href="{{ link.url }}">{{ link.title }}</a></li>{% endfor %}</ul></div>
      <div class="footer-col"><h3>Support</h3><ul>{% for link in footer_support_menu.links %}<li><a href="{{ link.url }}">{{ link.title }}</a></li>{% endfor %}</ul></div>
      <div class="footer-col"><h3>Company</h3><ul>{% for link in footer_company_menu.links %}<li><a href="{{ link.url }}">{{ link.title }}</a></li>{% endfor %}</ul></div>
      <div class="footer-col"><h3>Legal</h3><ul>{% for link in footer_legal_menu.links %}<li><a href="{{ link.url }}">{{ link.title }}</a></li>{% endfor %}</ul></div>
    </div>
    <div class="container footer-bottom">
      <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
      <p>{{ section.settings.footer_bottom_text }}</p>
    </div>
  </footer>

</div>

