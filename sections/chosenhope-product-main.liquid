{{ 'chosenhope-base.css' | asset_url | stylesheet_tag }}
{{ 'chosenhope-shop-grid.css' | asset_url | stylesheet_tag }}
{{ 'chosenhope-product.css' | asset_url | stylesheet_tag }}
<script src="{{ 'chosenhope-shop.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'chosenhope-product.js' | asset_url }}" defer="defer"></script>

{% liquid
  assign initial_variant = product.selected_or_first_available_variant
  assign initial_image = initial_variant.featured_image | default: product.featured_image
  assign gallery_images = product.images

  assign has_rating = false
  if product.metafields.reviews.rating.value != blank and product.metafields.reviews.rating_count.value != blank
    assign has_rating = true
    assign rating_value = product.metafields.reviews.rating.value
    assign rating_count = product.metafields.reviews.rating_count.value
    assign full_stars = rating_value | round
  endif

  assign swatch_option_names = section.settings.swatch_option_names | downcase | split: ','
%}

<div id="chosenhope-pdp-current-handle" data-handle="{{ product.handle }}" style="display:none;"></div>

<script type="application/json" id="chosenhope-pdp-variant-data">
  {
    "selectedOptions": {{ initial_variant.options | json }},
    "variants": [
      {% for variant in product.variants %}
        {
          "id": {{ variant.id | json }},
          "options": {{ variant.options | json }},
          "available": {{ variant.available | json }},
          "price_formatted": {{ variant.price | money | json }},
          {% if variant.compare_at_price > variant.price %}
            "compare_at_price_formatted": {{ variant.compare_at_price | money | json }},
          {% else %}
            "compare_at_price_formatted": null,
          {% endif %}
          {% assign v_image = variant.featured_image %}
          "featured_image_url": {{ v_image | image_url: width: 1200 | json }},
          "featured_image_alt": {{ v_image.alt | json }}
        }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ]
  }
</script>

<div class="chosenhope-home-scope">
  <div class="container">
    <div class="pdp-layout">
      <div class="pdp-gallery">
        <div id="chosenhope-pdp-main-image" class="pdp-main-image halo" role="button" tabindex="0" aria-label="Click to zoom">
          <div id="chosenhope-pdp-main-media">
            {% if initial_image != blank %}
              {{ initial_image | image_url: width: 1200 | image_tag: widths: '600,900,1200', alt: initial_image.alt, loading: 'eager' }}
            {% else %}
              <div class="fallback-photo fallback-photo--{{ section.settings.fallback_tone }}"><span class="fallback-symbol">✚</span></div>
            {% endif %}
          </div>
          {% if section.settings.show_zoom_hint %}
            <span class="pdp-zoom-hint">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"/><path d="M21 21l-4.3-4.3" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
              Click to zoom
            </span>
          {% endif %}
        </div>

        {% if gallery_images.size > 1 %}
          <div class="pdp-thumbs">
            {% for image in gallery_images %}
              <button
                type="button"
                class="pdp-thumb{% if image == initial_image %} active{% endif %}"
                data-image="{{ image | image_url: width: 1200 }}"
                data-alt="{{ image.alt | escape }}"
                aria-label="Show image {{ forloop.index }}"
              >
                {{ image | image_url: width: 200 | image_tag: widths: '100,200', alt: image.alt, loading: 'lazy' }}
              </button>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <div class="pdp-info">
        {% if section.settings.eyebrow != blank %}
          <span class="eyebrow">{{ section.settings.eyebrow }}</span>
        {% endif %}

        <h1 class="pdp-title">{{ product.title }}</h1>

        {% if product.description != blank %}
          <div class="pdp-desc">{{ product.description }}</div>
        {% endif %}

        {% if has_rating %}
          <div class="pdp-rating">
            <span class="stars" aria-hidden="true">{% for i in (1..5) %}{% if i <= full_stars %}★{% else %}☆{% endif %}{% endfor %}</span>
            <span>{{ rating_value }} · <a href="#chosenhope-reviews">{{ rating_count }} reviews</a></span>
          </div>
        {% endif %}

        <div class="pdp-price" id="chosenhope-pdp-price">
          <span>{{ initial_variant.price | money }}</span>
          {% if initial_variant.compare_at_price > initial_variant.price %}
            <span class="compare">{{ initial_variant.compare_at_price | money }}</span>
          {% endif %}
        </div>

        {% form 'product', product, id: 'chosenhope-product-form', data-type: 'add-to-cart-form' %}
          <input type="hidden" name="id" value="{{ initial_variant.id }}">

          {% for option in product.options_with_values %}
            {% assign option_index = forloop.index0 %}
            {% assign option_name_downcase = option.name | downcase %}
            {% assign is_swatch = false %}
            {% if swatch_option_names contains option_name_downcase %}
              {% assign is_swatch = true %}
            {% endif %}

            <div class="variant-group">
              <h3>{{ option.name }} — <span data-option-label="{{ option_index }}">{{ option.selected_value }}</span></h3>
              <div class="variant-options" role="group" aria-label="{{ option.name }}">
                {% for value in option.values %}
                  {% liquid
                    assign is_selected = false
                    if value == option.selected_value
                      assign is_selected = true
                    endif

                    assign value_available = false
                    for variant in product.variants
                      if variant.options[option_index] == value and variant.available
                        assign value_available = true
                      endif
                    endfor

                    assign value_handle = value | handleize
                    assign swatch_color = section.settings[value_handle]
                  %}

                  {% if is_swatch %}
                    <button
                      type="button"
                      class="variant-swatch{% if is_selected %} active{% endif %}"
                      style="background: {{ swatch_color | default: '#c8a24a' }};"
                      data-option-index="{{ option_index }}"
                      data-option-value="{{ value | escape }}"
                      aria-label="{{ value | escape }}"
                      aria-pressed="{{ is_selected }}"
                      {% unless value_available %}disabled{% endunless %}
                    ></button>
                  {% else %}
                    <button
                      type="button"
                      class="variant-pill{% if is_selected %} active{% endif %}"
                      data-option-index="{{ option_index }}"
                      data-option-value="{{ value | escape }}"
                      {% unless value_available %}disabled title="Out of stock"{% endunless %}
                    >{{ value }}</button>
                  {% endif %}
                {% endfor %}
              </div>
            </div>
          {% endfor %}

          <div class="qty-row">
            <div class="qty-stepper">
              <button type="button" aria-label="Decrease quantity" data-qty-decrease>−</button>
              <input type="text" inputmode="numeric" name="quantity" id="chosenhope-qty-input" value="1" readonly aria-label="Quantity" data-qty-input>
              <button type="button" aria-label="Increase quantity" data-qty-increase>+</button>
            </div>
          </div>

          <div class="pdp-actions" id="chosenhope-pdp-atc-anchor">
            <button
              type="button"
              class="pdp-wishlist-btn wishlist-btn"
              data-product-id="{{ product.id }}"
              data-label="{{ product.title | escape }}"
              aria-pressed="false"
              aria-label="Add {{ product.title | escape }} to wishlist"
            >
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 20s-7-4.4-9.3-8.8C1.2 8 2.6 4.8 6 4.2c2-.4 3.8.6 5 2.2 1.2-1.6 3-2.6 5-2.2 3.4.6 4.8 3.8 3.3 7C19 15.6 12 20 12 20Z" stroke="currentColor" stroke-width="1.6"/></svg>
            </button>
            <button
              type="submit"
              name="add"
              id="chosenhope-pdp-add-btn"
              class="btn btn-gold"
              {% unless initial_variant.available %}disabled{% endunless %}
            >
              <span data-add-text>{% if initial_variant.available %}Add to Cart{% else %}Sold out{% endif %}</span> — <span id="chosenhope-pdp-atc-price">{{ initial_variant.price | money }}</span>
            </button>
          </div>

          <p id="chosenhope-pdp-unavailable" class="pdp-unavailable" {% if initial_variant.available %}hidden{% endif %}>This combination is currently unavailable.</p>

          {% if section.settings.show_buy_now %}
            <div class="pdp-buy-now">
              {{ form | payment_button }}
            </div>
          {% endif %}
        {% endform %}

        {% if section.settings.trust_1 != blank or section.settings.trust_2 != blank or section.settings.trust_3 != blank %}
          <div class="trust-row">
            {% if section.settings.trust_1 != blank %}
              <span class="trust-item"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="5" y="11" width="14" height="9" rx="1.5" stroke="currentColor" stroke-width="1.6"/><path d="M8 11V8a4 4 0 0 1 8 0v3" stroke="currentColor" stroke-width="1.6"/></svg>{{ section.settings.trust_1 }}</span>
            {% endif %}
            {% if section.settings.trust_2 != blank %}
              <span class="trust-item"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M3 7h11v9H3zM14 10h4l3 3v3h-7z" stroke="currentColor" stroke-width="1.6"/><circle cx="7" cy="18" r="1.6" stroke="currentColor" stroke-width="1.4"/><circle cx="17.5" cy="18" r="1.6" stroke="currentColor" stroke-width="1.4"/></svg>{{ section.settings.trust_2 }}</span>
            {% endif %}
            {% if section.settings.trust_3 != blank %}
              <span class="trust-item"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 12l5 5L20 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>{{ section.settings.trust_3 }}</span>
            {% endif %}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

<div id="chosenhope-lightbox-backdrop" class="chosenhope-home-scope lightbox-backdrop">
  <button type="button" class="lightbox-close" data-lightbox-close aria-label="Close zoomed image">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M6 6l12 12M18 6 6 18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
  </button>
  <div id="chosenhope-lightbox-media" class="lightbox-image"></div>
</div>

{% render 'chosenhope-overlays', section: section %}

{% schema %}
{
  "name": "CH Product Main",
  "settings": [
    { "type": "checkbox", "id": "show_zoom_hint", "label": "Show \"Click to zoom\" hint", "default": true },
    {
      "type": "select",
      "id": "fallback_tone",
      "label": "Fallback color (used only when the product has no image)",
      "options": [
        { "value": "sand", "label": "Sand" },
        { "value": "olive", "label": "Olive" },
        { "value": "gold", "label": "Gold" },
        { "value": "cream", "label": "Cream" }
      ],
      "default": "sand"
    },
    { "type": "header", "content": "Info panel" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "info": "e.g. \"Signature · Cross Collection\". Leave blank to hide." },
    { "type": "text", "id": "swatch_option_names", "label": "Swatch-style option names", "default": "color,metal", "info": "Comma-separated, lowercase. Product options matching these names render as circular color swatches; all other options render as pill buttons." },
    { "type": "checkbox", "id": "show_buy_now", "label": "Show \"Buy it now\" dynamic checkout button", "default": true },
    { "type": "header", "content": "Trust badges" },
    { "type": "text", "id": "trust_1", "label": "Badge 1", "default": "Secure checkout" },
    { "type": "text", "id": "trust_2", "label": "Badge 2", "default": "Ships within 24 hours" },
    { "type": "text", "id": "trust_3", "label": "Badge 3", "default": "30-day easy returns" },
    { "type": "header", "content": "Swatch colors" },
    { "type": "paragraph", "content": "Optional: map specific option values to exact colors. Any value not listed here falls back to gold." },
    { "type": "color", "id": "gold-vermeil", "label": "\"Gold Vermeil\" swatch color", "default": "#c8a24a" },
    { "type": "color", "id": "sterling-silver", "label": "\"Sterling Silver\" swatch color", "default": "#b7b7b7" },
    { "type": "color", "id": "rose-gold", "label": "\"Rose Gold\" swatch color", "default": "#c99184" }
  ],
  "enabled_on": {
    "templates": ["product"]
  },
  "presets": [
    { "name": "CH Product Main" }
  ]
}
{% endschema %}
